{
    "name": "mars-client",
    "displayName": "Mars Client",
    "description": "A simple Rest API client",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "mars-client.openWebview",
                "title": "Mars Client: Open Webview"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "compile": "npm run build",
        "watch": "npx concurrently --raw \"npm run watch:webview\" \"npm run watch:extension\"",
        "watch:extension": "npx esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --format=cjs --platform=node --external:vscode --watch",
        "watch:webview": "cd webview && npx vite build --watch",
        "build": "npm run build:extension && npm run build:webview",
        "build:extension": "npx esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
        "build:webview": "cd webview && npm run build",
        "check-types": "tsc --noEmit",
        "lint": "npx eslint src",
        "test": "npx vscode-test",
        "vitest": "vitest run --config vitest.config.mts",
        "vitest:watch": "vitest --config vitest.config.mts",
        "vitest:ui": "vitest --ui --config vitest.config.mts"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.19.15",
        "@types/vscode": "^1.110.0",
        "@vitest/ui": "^4.1.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "concurrently": "^9.2.1",
        "esbuild": "^0.27.4",
        "eslint": "^9.39.3",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.1.0"
    }
}
